# ========================
# Schedule Pro - Environment Variables
# ========================

# Server
PORT=3000
NODE_ENV=development

# MongoDB (Atlas or local)
MONGO_URI=mongodb://localhost:27017/schedule_pro
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/schedule_pro

# JWT Secret (ganti dengan string random panjang)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# Fonnte WhatsApp API
FONNTE_TOKEN=your_fonnte_api_token_here

# Web Push (generate dengan: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@schedulepro.app

# Frontend URL (untuk CORS)
FRONTEND_URL=http://localhost:5500

# Owner default credentials (seed pertama kali)
OWNER_USERNAME=admin
OWNER_PASSWORD=Admin@Schedule123
OWNER_NAME=Administrator
OWNER_PHONE=628123456789
