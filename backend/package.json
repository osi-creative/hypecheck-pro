{
  "name": "schedule-pro-backend",
  "version": "1.0.0",
  "description": "Schedule Pro - PWA Scheduler Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node worker.js",
    "dev:worker": "nodemon worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:worker\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.3.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.2.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.0"
  }
}
